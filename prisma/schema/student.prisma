model Student {
    id           String          @id @default(uuid())
    studentId    String          @unique
    fullName     String
    email        String          @unique
    dob          DateTime
    programme    String
    academicYear String
    status       EnrolmentStatus @default(ENROLLED)
    feeAmount    Float
    grades       Grade[]
    payments     Payment[]
    submissions  Submission[]
    createdAt    DateTime        @default(now())
}
